# StockFlow Backend - ambiente LOCAL
NODE_ENV=development
PORT=3000

# PostgreSQL local via Docker ou instalado no Windows
DATABASE_URL=postgres://stockflow:stockflow@localhost:5432/stockflow
DB_SSL=false
DB_SYNC=true
DB_LOG=false
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=30000

# Segurança local
JWT_SECRET=stockflow_local_dev_secret_com_mais_de_32_caracteres
JWT_EXPIRES_IN=12h
SETUP_ADMIN_KEY=criar-admin-stockflow

# Admin local automático
# Com isso o backend cria/atualiza o admin ao iniciar.
AUTO_CREATE_ADMIN=true
DEFAULT_ADMIN_NAME=Administrador
DEFAULT_ADMIN_EMAIL=admin@local.com
DEFAULT_ADMIN_PASSWORD=admin123

# Frontend local autorizado
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173
CORS_ALLOW_VERCEL_PREVIEWS=false

# Inteligência viva / notificações automáticas
# Localmente pode deixar 15 para testar ou 0 para desligar.
TELECOMSTOCK_AUTO_INTELLIGENCE_MINUTES=15

# Uploads locais
UPLOAD_PUBLIC_BASE_URL=http://localhost:3000/uploads

# Aprovações
APPROVAL_ADMIN_MIN_AMOUNT=500
