# StockFlow Backend - Render + Neon
NODE_ENV=production
PORT=3000

# Neon PostgreSQL
# Copie a connection string do Neon. Exemplo:
# postgresql://usuario:senha@ep-alguma-coisa.us-east-2.aws.neon.tech/stockflow?sslmode=require
DATABASE_URL=postgresql://USUARIO:SENHA@HOST_NEON/stockflow?sslmode=require
DB_SSL=true

# Use true somente no primeiro deploy ou em atualizações que criam/alteram tabelas.
# Depois do banco sincronizar, volte para false.
DB_SYNC=true
DB_LOG=false
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=30000

# Segurança
JWT_SECRET=troque_por_uma_chave_grande_com_mais_de_32_caracteres
JWT_EXPIRES_IN=12h
SETUP_ADMIN_KEY=troque_por_uma_chave_de_primeiro_admin

# Admin automático
# Em produção, mantenha false. Para local/desenvolvimento, pode usar true.
AUTO_CREATE_ADMIN=false
DEFAULT_ADMIN_NAME=Administrador
DEFAULT_ADMIN_EMAIL=admin@local.com
DEFAULT_ADMIN_PASSWORD=troque_essa_senha

# Frontend autorizado no CORS
# Coloque a URL real da Vercel. Pode separar mais de uma URL com vírgula.
CORS_ORIGIN=https://seu-frontend.vercel.app
FRONTEND_URL=https://seu-frontend.vercel.app
CORS_ALLOW_VERCEL_PREVIEWS=false

# Inteligência viva / notificações automáticas
TELECOMSTOCK_AUTO_INTELLIGENCE_MINUTES=60

# Anexos. No Render Free/Starter, upload local pode ser temporário.
# Em produção avançada, prefira S3, Cloudinary ou outro storage externo.
UPLOAD_PUBLIC_BASE_URL=https://seu-backend.onrender.com/uploads

# Aprovações
APPROVAL_ADMIN_MIN_AMOUNT=500
